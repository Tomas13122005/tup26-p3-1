@page
@using razor.Models
@using razor.Services
@inject IContactoService ContactoService
@{
    List<Contacto> agenda = await ContactoService.ListarAsync();
    int idSeleccionado = 0;
    int.TryParse(Request.Query["id"], out idSeleccionado);

    Contacto? seleccionado = agenda.FirstOrDefault(contacto => contacto.Id == idSeleccionado)
        ?? agenda.FirstOrDefault();

    ViewData["Title"] = "Agenda";
    Layout = "_Layout";
}

<main class="maestro-detalle">
    <aside class="panel-lista">
        <header class="panel-lista-header">
            <h1>Agenda</h1>
        </header>

        <ul class="lista-contactos">
            @foreach (Contacto contacto in agenda) {
                string clase = contacto.Id == seleccionado?.Id ? "seleccionado" : "";

                <li>
                    <a class="@clase" href="/?id=@contacto.Id">
                        <span>@contacto.Nombre @contacto.Apellido</span>
                        @if (contacto.Favorito) {
                            <strong>★</strong>
                        }
                    </a>
                </li>
            }
        </ul>
    </aside>

    <section class="panel-detalle">
        @if (seleccionado is not null) {
            <div class="detalle-contacto">
                <header class="detalle-header">
                    <div>
                        <p>Contacto</p>
                        <h2>@seleccionado.Nombre @seleccionado.Apellido</h2>
                    </div>
                    <span class="estrella @(seleccionado.Favorito ? "favorito" : "")">★</span>
                </header>

                <dl>
                    <dt>Telefono</dt>
                    <dd>📞 @seleccionado.Telefono</dd>

                    <dt>Email</dt>
                    <dd>
                        @if (seleccionado.Email is not null) {
                            <span>📧 @seleccionado.Email</span>
                        } else {
                            <span class="texto-muted">Sin email</span>
                        }
                    </dd>

                    <dt>Favorito</dt>
                    <dd>@(seleccionado.Favorito ? "Si" : "No")</dd>
                </dl>
            </div>
        }
    </section>
</main>
